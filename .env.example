# ── LLM (Groq) ────────────────────────────────────────────────────────────────
# Primary LLM provider. Use "groq" (default) or "ollama" (requires NVIDIA GPU).
LLM_PROVIDER=groq

# Groq API key — free tier at https://console.groq.com
GROQ_API_KEY=

# Groq model IDs (llama-3.3 supersedes decommissioned llama-3.1)
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_WHISPER_MODEL=whisper-large-v3

# ── Embeddings ────────────────────────────────────────────────────────────────
# "jina" (default, 1M free tokens) or "gemini"
EMBED_PROVIDER=jina

# Jina AI — https://jina.ai (free tier: 1M tokens)
JINA_API_KEY=
JINA_EMBED_MODEL=jina-embeddings-v3

# Gemini (fallback) — https://aistudio.google.com
GEMINI_API_KEY=
GEMINI_EMBED_MODEL=text-embedding-004

# ── TTS ───────────────────────────────────────────────────────────────────────
# "elevenlabs" (default, 10k chars/mo free), "hf_space" (XTTS-v2 via HF), or "mock" (silent audio for testing)
TTS_PROVIDER=elevenlabs

# ElevenLabs — https://elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Coqui XTTS-v2 via Hugging Face Space (set TTS_PROVIDER=hf_space to use)
HF_SPACE_XTTS_URL=

# ── VAD ───────────────────────────────────────────────────────────────────────
# Silence duration (ms) webrtcvad must observe before declaring end-of-speech.
# Default 300 ms is safe for Hinglish code-switching. Min enforced: 150 ms.
# Reducing to 200 ms cuts perceived latency ~100 ms but risks clipping pauses.
VAD_SILENCE_PADDING_MS=300

# ── Databases ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://saarthi:saarthi@localhost:5432/saarthi
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=saarthi_neo4j

# ── Object storage (MinIO) ────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=saarthi
MINIO_USE_SSL=false

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development

# LangSmith tracing (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=saarthi

# ── Web UI ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
